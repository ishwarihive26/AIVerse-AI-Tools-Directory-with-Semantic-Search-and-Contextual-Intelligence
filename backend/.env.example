# Copy this file to .env and fill in real values.
# .env is git-ignored and never gets committed.

# MySQL connection string
# Format: mysql+pymysql://<user>:<password>@<host>:<port>/<database_name>
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/ai_tools_directory

# Used later for JWT auth
SECRET_KEY=change-this-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Used later for image uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Allows the backend to accept requests from the frontend
FRONTEND_URL=http://localhost:3000
